# Copy to .env and fill in your keys
# The gateway uses this for server-side text embeddings (RAG search).
# Chat API keys are provided by the user in the browser (X-API-Key header).

OPENAI_API_KEY=sk-...
EMBEDDING_PROVIDER=auto
# auto = use OpenAI if key is set, otherwise local sentence-transformers
# openai = force OpenAI embeddings
# local  = force local sentence-transformers (no API key needed, slower)
